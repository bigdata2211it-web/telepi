# TelePi Configuration
# Copy to ~/.config/telepi/config.env and edit

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Allowed Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USER_IDS=123456789

# Workspace directory (where sessions and files are stored)
TELEPI_WORKSPACE=/home/debi/projects

# Pi AI settings
PI_SESSION_PATH=
PI_MODEL=

# Optional: OpenAI API key (fallback for voice transcription)
OPENAI_API_KEY=

# Sherpa-ONNX model directory (optional, for local voice)
SHERPA_ONNX_MODEL_DIR=
SHERPA_ONNX_NUM_THREADS=2
